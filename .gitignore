------------------------------
-- Меню: открытие/закрытие
------------------------------
local function openMenu()
	menuOpen = true
	menuFrame.Visible = true
	menuFrame.Size = UDim2.new(0, 0, 0, 0)
	menuFrame.Position = UDim2.new(0, 80, 0.5, 0)
	TweenService:Create(menuFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 300, 0, 550),
		Position = UDim2.new(0, 80, 0.5, -275)
	}):Play()
end

local function closeMenu()
	menuOpen = false
	local t = TweenService:Create(menuFrame, TweenInfo.new(0.2), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0, 80, 0.5, 0)
	})
	t:Play()
	t.Completed:Connect(function() menuFrame.Visible = false end)
end

menuToggleBtn.MouseButton1Click:Connect(function()
	if menuOpen then closeMenu() else openMenu() end
end)
closeBtn.MouseButton1Click:Connect(closeMenu)

------------------------------
-- Перетаскивание
------------------------------
local dragStart, startPos, dragging = nil, nil, false

header.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = i.Position
		startPos = menuFrame.Position
	end
end)
UserInputService.InputChanged:Connect(function(i)
	if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = i.Position - dragStart
		menuFrame.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)
UserInputService.InputEnded:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

------------------------------
-- Суставы
------------------------------
local function saveJointsFn()
	local char = player.Character
	if not char then return end
	savedJoints = {}
	for _, v in pairs(char:GetDescendants()) do
		if v:IsA("Motor6D") then
			savedJoints[#savedJoints + 1] = {j = v, c0 = v.C0}
		end
	end
end

local function restoreJoints()
	for _, d in pairs(savedJoints) do
		if d.j and d.j.Parent then d.j.C0 = d.c0 end
	end
	savedJoints = {}
end

------------------------------
-- Lock-On
------------------------------
local function getCenterPos()
	local size = camera.ViewportSize
	local ray = camera:ViewportPointToRay(size.X / 2, size.Y / 2)
	local res = workspace:Raycast(ray.Origin, ray.Direction * 1000)
	return res and res.Position or (ray.Origin + ray.Direction * 500)
end

local function rotateToCenter()
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	local tp = getCenterPos()
	local dir = Vector3.new(tp.X - root.Position.X, 0, tp.Z - root.Position.Z)
	if dir.Magnitude < 1 then return end
	local vel = root.AssemblyLinearVelocity
	root.CFrame = CFrame.lookAt(root.Position, root.Position + dir.Unit)
	root.AssemblyLinearVelocity = vel
end

local function getClosest()
	local closest, dist = nil, MAX_DISTANCE
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return nil end
	for _, v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model") and v ~= player.Character then
			local hrp = v:FindFirstChild("HumanoidRootPart")
			local hum = v:FindFirstChildOfClass("Humanoid")
			if hrp and hum and hum.Health > 0 then
				local d = (root.Position - hrp.Position).Magnitude
				if d < dist then dist = d closest = hrp end
			end
		end
	end
	return closest
end

local function resetLock()
	isLocked = false
	target = nil
	lockPaused = false
	local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if h then h.AutoRotate = true end
	setToggleUI(lockUI, false)
end

local function toggleLock()
	isLocked = not isLocked
	if isLocked then
		target = getClosest()
		if target then
			local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
			if h then h.AutoRotate = false end
		else
			isLocked = false
		end
	else
		resetLock()
		return
	end
	setToggleUI(lockUI, isLocked)
end

lockUI.btn.MouseButton1Click:Connect(toggleLock)

RunService.Heartbeat:Connect(function()
	if not isLocked or not target or lockPaused then return end
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	if not target.Parent then resetLock() return end
	local tHum = target.Parent:FindFirstChildOfClass("Humanoid")
	if not tHum or tHum.Health <= 0 then resetLock() return end

	local myP, tarP = root.Position, target.Position
	local flatDist = Vector2.new(tarP.X - myP.X, tarP.Z - myP.Z).Magnitude
	local fullDist = (myP - tarP).Magnitude

	if fullDist > MAX_DISTANCE then resetLock() return end
	if flatDist < 2 then return end
	if flatDist < 10 and math.abs(tarP.Y - myP.Y) > 4 then return end
	if flatDist < 5 and math.abs(tarP.Y - myP.Y) > 2 then return end

	local vel = root.AssemblyLinearVelocity
	local angVel = root.AssemblyAngularVelocity
	root.CFrame = CFrame.lookAt(myP, Vector3.new(tarP.X, myP.Y, tarP.Z))
	root.AssemblyLinearVelocity = vel
	root.AssemblyAngularVelocity = angVel
end)

------------------------------
-- Клавиши
------------------------------
UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end

	if input.KeyCode == LOCK_KEY then
		toggleLock()
		return
	end

	for _, k in pairs(MOVE_KEYS) do
		if input.KeyCode == k then
			antiStunPaused = true
			task.delay(ANTI_STUN_PAUSE, function() antiStunPaused = false end)
			if isLocked then
				rotateToCenter()
				lockPaused = true
				task.delay(MOVE_PAUSE_TIME, function() lockPaused = false end)
			end
			break
		end
	end

	if input.KeyCode == DASH_KEY and isLocked then
		lockPaused = true
		task.delay(DASH_PAUSE_TIME, function() lockPaused = false end)
	end
end)

------------------------------
-- Полёт
------------------------------
local function applySuperman(char)
	local isR15 = char:FindFirstChild("UpperTorso") ~= nil
	for _, v in pairs(char:GetDescendants()) do
		if v:IsA("Motor6D") then
			if isR15 then
				if v.Name == "RightShoulder" then
					v.C0 = CFrame.new(1, 0.5, 0) * CFrame.Angles(math.rad(-170), 0, 0)
				elseif v.Name == "LeftShoulder" then
					v.C0 = CFrame.new(-1, 0.5, 0) * CFrame.Angles(math.rad(10), 0, 0)
				end
			else
				if v.Name == "Right Shoulder" then
					v.C0 = CFrame.new(1, 0.5, 0) * CFrame.Angles(0, math.rad(90), math.rad(170))
				elseif v.Name == "Left Shoulder" then
					v.C0 = CFrame.new(-1, 0.5, 0) * CFrame.Angles(0, math.rad(-90), math.rad(10))
				end
			end
		end
	end
end

local function startFly()
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	local root = char.HumanoidRootPart
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	saveJointsFn()
	hum.PlatformStand = true
	if char:FindFirstChild("Animate") then char.Animate.Disabled = true end

	if flyBodyVelocity then flyBodyVelocity:Destroy() end
	if flyBodyGyro then flyBodyGyro:Destroy() end

	flyBodyVelocity = Instance.new("BodyVelocity", root)
	flyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	flyBodyVelocity.Velocity = Vector3.zero

	flyBodyGyro = Instance.new("BodyGyro", root)
	flyBodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
	flyBodyGyro.D = 1500
	flyBodyGyro.P = 300000

	flyConnection = RunService.RenderStepped:Connect(function()
		if not flyEnabled then return end
		local char2 = player.Character
		if not char2 then return end
		applySuperman(char2)

		local dir = Vector3.zero
		local cl = camera.CFrame.LookVector
		local cr = camera.CFrame.RightVector
		local fl = Vector3.new(cl.X, 0, cl.Z)
		if fl.Magnitude > 0.01 then fl = fl.Unit end
		local fr = Vector3.new(cr.X, 0, cr.Z)
		if fr.Magnitude > 0.01 then fr = fr.Unit end

		if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += fl end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= fl end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= fr end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += fr end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.yAxis end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
			local root2 = char2:FindFirstChild("HumanoidRootPart")
			if root2 then
				local res = workspace:Raycast(root2.Position, Vector3.new(0, -500, 0))
				local gd = res and (root2.Position - res.Position).Magnitude or math.huge
				if gd > 5 then dir -= Vector3.yAxis end
			end
		end

		flyBodyVelocity.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.zero

		local tilt = 0
		local hasH = Vector3.new(dir.X, 0, dir.Z).Magnitude > 0.01
		if hasH and dir.Y ~= 0 then
			tilt = dir.Y > 0 and -25 or 25
		elseif hasH then
			tilt = -20
		end

		local baseDir = Vector3.new(dir.X, 0, dir.Z)
		if baseDir.Magnitude > 0.01 then
			flyBodyGyro.CFrame = CFrame.lookAt(Vector3.zero, baseDir.Unit) * CFrame.Angles(math.rad(tilt), 0, 0)
		end
	end)
end

local function stopFly()
	if flyConnection then flyConnection:Disconnect() flyConnection = nil end
	if flyBodyVelocity then flyBodyVelocity:Destroy() flyBodyVelocity = nil end
	if flyBodyGyro then flyBodyGyro:Destroy() flyBodyGyro = nil end
	restoreJoints()
	local char = player.Character
	if char then
		if char:FindFirstChild("Animate") then char.Animate.Disabled = false end
		local h = char:FindFirstChildOfClass("Humanoid")
		if h then
			h.PlatformStand = false
			h:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
	end
end

flyUI.btn.MouseButton1Click:Connect(function()
	flyEnabled = not flyEnabled
	if flyEnabled then startFly() else stopFly() end
	setToggleUI(flyUI, flyEnabled)
end)

------------------------------
-- Прыжки
------------------------------
jumpUI.btn.MouseButton1Click:Connect(function()
	infJumpEnabled = not infJumpEnabled
	setToggleUI(jumpUI, infJumpEnabled)
end)

UserInputService.JumpRequest:Connect(function()
	if not infJumpEnabled then return end
	local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if h and h.Health > 0 then
		h.JumpPower = jumpPower
		h:ChangeState(Enum.HumanoidStateType.Jumping)
	end
end)

------------------------------
-- Скорость + Анти-стан
------------------------------
speedUI.btn.MouseButton1Click:Connect(function()
	speedEnabled = not speedEnabled
	setToggleUI(speedUI, speedEnabled)
	if not speedEnabled then
		local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if h then h.WalkSpeed = defaultSpeed end
	end
end)

RunService.Heartbeat:Connect(function()
	if not speedEnabled then return end
	local char = player.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	hum.WalkSpeed = customSpeed

	if antiStunPaused or flyEnabled then return end

	if hum.PlatformStand then hum.PlatformStand = false end
	if hum.Sit then hum.Sit = false end

	local state = hum:GetState()
	if state == Enum.HumanoidStateType.Ragdoll
		or state == Enum.HumanoidStateType.FallingDown then
		hum:ChangeState(Enum.HumanoidStateType.GettingUp)
	end

	local root = char:FindFirstChild("HumanoidRootPart")
	if root then
		if root.Anchored then root.Anchored = false end
		for _, obj in pairs(root:GetChildren()) do
			if obj.Name ~= "FlyVelocity" and obj.Name ~= "FlyGyro" then
				if obj:IsA("BodyPosition") then obj:Destroy() end
				if obj:IsA("BodyVelocity") and obj.Velocity.Magnitude < 0.1 then obj:Destroy() end
			end
		end
	end
end)

------------------------------
-- Сброс при смерти
------------------------------
player.CharacterAdded:Connect(function()
	resetLock()
	if flyEnabled then
		flyEnabled = false
		setToggleUI(flyUI, false)
		stopFly()
	end
	if speedEnabled then
		task.wait(0.5)
		local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if h then h.WalkSpeed = customSpeed end
	end
end)
