-- Загружаем картинку
task.spawn(function()
	local decalId = 107051278969038
	local loaded = false

	pcall(function()
		local objs = game:GetObjects("rbxassetid://" .. decalId)
		if objs and objs[1] then
			local obj = objs[1]
			if obj:IsA("Decal") then
				bgImage.Image = obj.Texture
				loaded = true
			else
				local d = obj:FindFirstChildOfClass("Decal")
				if d then bgImage.Image = d.Texture loaded = true end
			end
			obj:Destroy()
		end
	end)

	if not loaded then
		pcall(function()
			local model = game:GetService("InsertService"):LoadAsset(decalId)
			for _, v in pairs(model:GetDescendants()) do
				if v:IsA("Decal") then
					bgImage.Image = v.Texture
					loaded = true
					break
				end
			end
			model:Destroy()
		end)
	end

	if not loaded then
		bgImage.Image = "rbxassetid://" .. decalId
	end
end)

