------------------------------
-- Функция обновления UI
------------------------------
local function setToggleUI(ui, on)
	if on then
		ui.status.Text = "ВКЛ"
		ui.status.BackgroundColor3 = Color3.fromRGB(170, 30, 30)
		ui.status.TextColor3 = Color3.fromRGB(255, 255, 255)
		ui.btnStroke.Color = Color3.fromRGB(220, 60, 60)
		ui.btn.BackgroundColor3 = Color3.fromRGB(35, 20, 20)
	else
		ui.status.Text = "ВЫКЛ"
		ui.status.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
		ui.status.TextColor3 = Color3.fromRGB(150, 150, 150)
		ui.btnStroke.Color = Color3.fromRGB(60, 60, 90)
		ui.btn.BackgroundColor3 = Color3.fromRGB(28, 28, 42)
	end
end

------------------------------
-- LOCK-ON
------------------------------
local function getClosestTarget()
	local closestRoot = nil
	local shortestDist = MAX_DISTANCE
	local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not myRoot then return nil end

	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Model") then
			local root = obj:FindFirstChild("HumanoidRootPart")
			local hum = obj:FindFirstChildOfClass("Humanoid")
			if root and hum and hum.Health > 0 and obj ~= player.Character then
				local dist = (myRoot.Position - root.Position).Magnitude
				if dist < shortestDist then
					shortestDist = dist
					closestRoot = root
				end
			end
		end
	end
	return closestRoot
end

local function resetLock()
	isLocked = false
	target = nil
	local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if hum then hum.AutoRotate = true end
	lockUI.icon.Text = "🔓"
	setToggleUI(lockUI, false)
end

local function toggleLock()
	isLocked = not isLocked
	if isLocked then
		target = getClosestTarget()
		if target then
			local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
			if hum then hum.AutoRotate = false end
			lockUI.icon.Text = "🔒"
		else
			isLocked = false
		end
	else
		resetLock()
		return
	end
	setToggleUI(lockUI, isLocked)
end

lockUI.btn.MouseButton1Click:Connect(toggleLock)

------------------------------
-- ПОЛЁТ
------------------------------
local flyConnection = nil

local function startFly()
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not root or not hum then return end

	if flyBodyVelocity then flyBodyVelocity:Destroy() end
	if flyBodyGyro then flyBodyGyro:Destroy() end

	hum.PlatformStand = true

	flyBodyVelocity = Instance.new("BodyVelocity")
	flyBodyVelocity.Velocity = Vector3.zero
	flyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	flyBodyVelocity.Parent = root

	flyBodyGyro = Instance.new("BodyGyro")
	flyBodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
	flyBodyGyro.P = 1000000
	flyBodyGyro.D = 100
	flyBodyGyro.Parent = root

	flyConnection = RunService.RenderStepped:Connect(function()
		if not flyEnabled or not root or not root.Parent then return end

		flyBodyGyro.CFrame = camera.CFrame

		local dir = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.yAxis end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir -= Vector3.yAxis end

		flyBodyVelocity.Velocity = if dir.Magnitude > 0 then dir.Unit * flySpeed else Vector3.zero
	end)
end

local function stopFly()
	if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
	if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
	if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end

	local char = player.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then hum.PlatformStand = false end
	end
end

local function toggleFly()
	flyEnabled = not flyEnabled
	if flyEnabled then
		startFly()
		flyUI.icon.Text = "✈️"
	else
		stopFly()
		flyUI.icon.Text = "🕊️"
	end
	setToggleUI(flyUI, flyEnabled)
end

flyUI.btn.MouseButton1Click:Connect(toggleFly)

------------------------------
-- БЕСКОНЕЧНЫЕ ПРЫЖКИ
------------------------------
local jumpConnection = nil

local function toggleInfJump()
	infJumpEnabled = not infJumpEnabled
	if infJumpEnabled then
		jumpUI.icon.Text = "🚀"
		jumpConnection = UserInputService.JumpRequest:Connect(function()
			if not infJumpEnabled then return end
			local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				hum.JumpPower = jumpPower
				hum:ChangeState(Enum.HumanoidStateType.Jumping)
			end
		end)
	else
		jumpUI.icon.Text = "⬆️"
		if jumpConnection then jumpConnection:Disconnect(); jumpConnection = nil end
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum.JumpPower = 50 end
	end
	setToggleUI(jumpUI, infJumpEnabled)
end

jumpUI.btn.MouseButton1Click:Connect(toggleInfJump)

------------------------------
-- СКОРОСТЬ
------------------------------
local speedLoop = nil

local function toggleSpeed()
	speedEnabled = not speedEnabled
	if speedEnabled then
		speedUI.icon.Text = "💨"

		-- Применяем сразу
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed = customSpeed end

		-- Цикл чтобы скорость не сбрасывалась игрой
		speedLoop = RunService.Heartbeat:Connect(function()
			if not speedEnabled then return end
			local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
			if hum then
				hum.WalkSpeed = customSpeed
			end
		end)
	else
		speedUI.icon.Text = "🏃"
		if speedLoop then speedLoop:Disconnect(); speedLoop = nil end

		-- Возвращаем стандартную скорость
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed = defaultSpeed end
	end
	setToggleUI(speedUI, speedEnabled)
end

speedUI.btn.MouseButton1Click:Connect(toggleSpeed)

------------------------------
-- Меню: открытие / закрытие
------------------------------
local function openMenu()
	menuOpen = true
	menuFrame.Visible = true
	menuFrame.Size = UDim2.new(0, 0, 0, 0)
	menuFrame.Position = UDim2.new(0, 80, 0.5, 0)

	TweenService:Create(menuFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 300, 0, 550),
		Position = UDim2.new(0, 80, 0.5, -275)
	}):Play()
end

local function closeMenu()
	menuOpen = false
	local t = TweenService:Create(menuFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0, 80, 0.5, 0)
	})
	t:Play()
	t.Completed:Connect(function()
		menuFrame.Visible = false
	end)
end

menuToggleBtn.MouseButton1Click:Connect(function()
	if menuOpen then closeMenu() else openMenu() end
end)

closeBtn.MouseButton1Click:Connect(closeMenu)

------------------------------
-- Перетаскивание меню
------------------------------
local dragging = false
local dragStart, frameStart

header.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = Vector2.new(input.Position.X, input.Position.Y)
		frameStart = menuFrame.Position
	end
end)

header.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStart
		menuFrame.Position = UDim2.new(
			frameStart.X.Scale, frameStart.X.Offset + delta.X,
			frameStart.Y.Scale, frameStart.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

------------------------------
-- Клавиша L
------------------------------
UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == LOCK_KEY then toggleLock() end
end)

------------------------------
-- Поворот персонажа (Lock-On)
------------------------------
RunService.RenderStepped:Connect(function()
	if not isLocked or not target then return end
	if camera.CameraType ~= Enum.CameraType.Custom then return end

	local char = player.Character
	if not char then return end
	local myRoot = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not myRoot or not hum then return end

	local state = hum:GetState()
	if state == Enum.HumanoidStateType.Dead
		or state == Enum.HumanoidStateType.Physics
		or state == Enum.HumanoidStateType.Ragdoll
		or state == Enum.HumanoidStateType.FallingDown then
		return
	end

	if not target.Parent then resetLock() return end
	local tHum = target.Parent:FindFirstChildOfClass("Humanoid")
	if not tHum or tHum.Health <= 0 then resetLock() return end

	local dist = (myRoot.Position - target.Position).Magnitude
	if dist > MAX_DISTANCE then resetLock() return end

	local myPos = myRoot.Position
	local dir = Vector3.new(target.Position.X - myPos.X, 0, target.Position.Z - myPos.Z)
	if dir.Magnitude < 1 then return end

	local vel = myRoot.AssemblyLinearVelocity
	myRoot.CFrame = CFrame.lookAt(myPos, myPos + dir.Unit)
	myRoot.AssemblyLinearVelocity = vel
end)

------------------------------
-- Сброс при смерти
------------------------------
player.CharacterAdded:Connect(function()
	resetLock()
	if flyEnabled then
		flyEnabled = false
		setToggleUI(flyUI, false)
		flyUI.icon.Text = "🕊️"
		stopFly()
	end
	-- Переприменяем скорость после респавна
	if speedEnabled then
		task.wait(0.5)
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed = customSpeed end
	end
end)
