local function createSection(text)
	local sec = Instance.new("TextLabel")
	sec.Size = UDim2.new(1, 0, 0, 25)
	sec.BackgroundTransparency = 1
	sec.Text = "  " .. text
	sec.TextSize = 14
	sec.Font = Enum.Font.GothamBold
	sec.TextColor3 = COLORS.section
	sec.TextXAlignment = Enum.TextXAlignment.Left
	sec.ZIndex = 7
	sec.LayoutOrder = nextOrder()
	sec.Parent = list
end

local function createToggle(labelText, hasSettings)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1, 0, 0, 50)
	container.BackgroundTransparency = 1
	container.ZIndex = 7
	container.LayoutOrder = nextOrder()
	container.ClipsDescendants = true
	container.Parent = list

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 50)
	btn.BackgroundColor3 = COLORS.btnBg
	btn.BackgroundTransparency = 0.5
	btn.Text = ""
	btn.ZIndex = 7
	btn.Parent = container
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
	local bs = Instance.new("UIStroke", btn)
	bs.Color = COLORS.stroke
	bs.Thickness = 1

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -120, 1, 0)
	label.Position = UDim2.new(0, 14, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = labelText
	label.TextSize = 15
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = COLORS.text
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.ZIndex = 8
	label.Parent = btn

	local status = Instance.new("TextLabel")
	status.Size = UDim2.new(0, 48, 0, 22)
	status.Position = UDim2.new(1, -100, 0.5, -11)
	status.BackgroundColor3 = COLORS.statusOff
	status.Text = "OFF"
	status.TextSize = 11
	status.Font = Enum.Font.GothamBold
	status.TextColor3 = COLORS.statusOffText
	status.ZIndex = 8
	status.Parent = btn
	Instance.new("UICorner", status).CornerRadius = UDim.new(0, 6)

	local settingsBtn, settingsPanel
	if hasSettings then
		settingsBtn = Instance.new("TextButton")
		settingsBtn.Size = UDim2.new(0, 28, 0, 28)
		settingsBtn.Position = UDim2.new(1, -40, 0.5, -14)
		settingsBtn.BackgroundColor3 = COLORS.bg
		settingsBtn.Text = "..."
		settingsBtn.TextColor3 = COLORS.textBright
		settingsBtn.ZIndex = 9
		settingsBtn.Parent = btn
		Instance.new("UICorner", settingsBtn).CornerRadius = UDim.new(0, 8)
		Instance.new("UIStroke", settingsBtn).Color = COLORS.stroke

		settingsPanel = Instance.new("Frame")
		settingsPanel.Size = UDim2.new(1, -10, 0, 80)
		settingsPanel.Position = UDim2.new(0, 5, 0, 55)
		settingsPanel.BackgroundColor3 = COLORS.bg
		settingsPanel.BackgroundTransparency = 0.5
		settingsPanel.Visible = false
		settingsPanel.ZIndex = 7
		settingsPanel.Parent = container
		Instance.new("UICorner", settingsPanel).CornerRadius = UDim.new(0, 8)
		Instance.new("UIStroke", settingsPanel).Color = COLORS.stroke

		-- Добавляем UIListLayout для слайдеров
		local panelLayout = Instance.new("UIListLayout", settingsPanel)
		panelLayout.Padding = UDim.new(0, 4)
		local panelPad = Instance.new("UIPadding", settingsPanel)
		panelPad.PaddingTop = UDim.new(0, 6)

		local open = false
		settingsBtn.MouseButton1Click:Connect(function()
			open = not open
			settingsPanel.Visible = open
			container.Size = open and UDim2.new(1, 0, 0, 145) or UDim2.new(1, 0, 0, 50)
		end)
	end

	return {btn = btn, status = status, bs = bs, settingsPanel = settingsPanel}
end

local function createSlider(parent, text, minV, maxV, default, callback)
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1, -16, 0, 34)
	frame.BackgroundTransparency = 1
	frame.Parent = parent

	local sLabel = Instance.new("TextLabel")
	sLabel.Size = UDim2.new(0.4, 0, 1, 0)
	sLabel.Position = UDim2.new(0, 8, 0, 0)
	sLabel.BackgroundTransparency = 1
	sLabel.Text = text
	sLabel.TextSize = 13
	sLabel.Font = Enum.Font.GothamBold
	sLabel.TextColor3 = COLORS.textDim
	sLabel.TextXAlignment = Enum.TextXAlignment.Left
	sLabel.ZIndex = 9
	sLabel.Parent = frame

	local valLabel = Instance.new("TextLabel")
	valLabel.Size = UDim2.new(0, 40, 1, 0)
	valLabel.Position = UDim2.new(1, -40, 0, 0)
	valLabel.BackgroundTransparency = 1
	valLabel.Text = tostring(default)
	valLabel.TextColor3 = COLORS.textBright
	valLabel.Font = Enum.Font.GothamBold
	valLabel.TextSize = 13
	valLabel.ZIndex = 9
	valLabel.Parent = frame

	local track = Instance.new("Frame")
	track.Size = UDim2.new(0.4, 0, 0, 4)
	track.Position = UDim2.new(0.45, 0, 0.5, -2)
	track.BackgroundColor3 = COLORS.sliderTrack
	track.ZIndex = 9
	track.Parent = frame
	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new((default - minV) / (maxV - minV), 0, 1, 0)
	fill.BackgroundColor3 = COLORS.sliderFill
	fill.ZIndex = 10
	fill.Parent = track
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("TextButton")
	knob.Size = UDim2.new(0, 14, 0, 14)
	knob.Position = UDim2.new((default - minV) / (maxV - minV), -7, 0.5, -7)
	knob.BackgroundColor3 = COLORS.sliderKnob
	knob.Text = ""
	knob.ZIndex = 11
	knob.Parent = track
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local sliding = false
	knob.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true end
	end)
	UserInputService.InputChanged:Connect(function(i)
		if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
			local pct = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
			local val = math.floor(minV + (maxV - minV) * pct)
			fill.Size = UDim2.new(pct, 0, 1, 0)
			knob.Position = UDim2.new(pct, -7, 0.5, -7)
			valLabel.Text = tostring(val)
			callback(val)
		end
	end)
	UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
	end)
end

local function setToggleUI(ui, on)
	ui.status.Text = on and "ON" or "OFF"
	ui.status.BackgroundColor3 = on and COLORS.statusOn or COLORS.statusOff
	ui.status.TextColor3 = on and Color3.new(1, 1, 1) or COLORS.statusOffText
	ui.bs.Color = on and COLORS.strokeActive or COLORS.stroke
	ui.btn.BackgroundColor3 = on and COLORS.btnBgActive or COLORS.btnBg
end

