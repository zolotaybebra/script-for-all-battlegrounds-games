------------------------------
-- Утилиты создания UI
------------------------------
local orderIndex = 0
local function nextOrder()
	orderIndex += 1
	return orderIndex
end

local function createSection(text)
	local sec = Instance.new("TextLabel")
	sec.Size = UDim2.new(1, 0, 0, 22)
	sec.BackgroundTransparency = 1
	sec.Text = "  " .. text
	sec.TextSize = 13
	sec.Font = Enum.Font.GothamBold
	sec.TextColor3 = Color3.fromRGB(120, 120, 180)
	sec.TextXAlignment = Enum.TextXAlignment.Left
	sec.ZIndex = 7
	sec.LayoutOrder = nextOrder()
	sec.Parent = list
end

local function createToggle(labelText, iconText, hasSettings)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1, 0, 0, 55)
	container.BackgroundTransparency = 1
	container.ZIndex = 7
	container.LayoutOrder = nextOrder()
	container.ClipsDescendants = true
	container.Parent = list

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 55)
	btn.BackgroundColor3 = Color3.fromRGB(28, 28, 42)
	btn.AutoButtonColor = false
	btn.Text = ""
	btn.ZIndex = 7
	btn.Parent = container

	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

	local btnStroke = Instance.new("UIStroke", btn)
	btnStroke.Color = Color3.fromRGB(60, 60, 90)
	btnStroke.Thickness = 1.5

	local icon = Instance.new("TextLabel")
	icon.Size = UDim2.new(0, 36, 0, 55)
	icon.Position = UDim2.new(0, 10, 0, 0)
	icon.BackgroundTransparency = 1
	icon.Text = iconText
	icon.TextSize = 20
	icon.Font = Enum.Font.GothamBold
	icon.TextColor3 = Color3.fromRGB(200, 200, 200)
	icon.ZIndex = 8
	icon.Parent = btn

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -140, 0, 55)
	label.Position = UDim2.new(0, 50, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = labelText
	label.TextSize = 15
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = Color3.fromRGB(220, 220, 220)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.ZIndex = 8
	label.Parent = btn

	local status = Instance.new("TextLabel")
	status.Size = UDim2.new(0, 48, 0, 24)
	status.Position = UDim2.new(1, -100, 0.5, -12)
	status.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
	status.Text = "ВЫКЛ"
	status.TextSize = 12
	status.Font = Enum.Font.GothamBold
	status.TextColor3 = Color3.fromRGB(150, 150, 150)
	status.ZIndex = 8
	status.Parent = btn

	Instance.new("UICorner", status).CornerRadius = UDim.new(0, 6)

	local settingsBtn = nil
	local settingsPanel = nil

	if hasSettings then
		settingsBtn = Instance.new("TextButton")
		settingsBtn.Size = UDim2.new(0, 30, 0, 30)
		settingsBtn.Position = UDim2.new(1, -42, 0.5, -15)
		settingsBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
		settingsBtn.Text = "⚙"
		settingsBtn.TextSize = 16
		settingsBtn.Font = Enum.Font.GothamBold
		settingsBtn.TextColor3 = Color3.fromRGB(180, 180, 220)
		settingsBtn.AutoButtonColor = false
		settingsBtn.ZIndex = 9
		settingsBtn.Parent = btn

		Instance.new("UICorner", settingsBtn).CornerRadius = UDim.new(0, 8)

		settingsPanel = Instance.new("Frame")
		settingsPanel.Size = UDim2.new(1, -10, 0, 80)
		settingsPanel.Position = UDim2.new(0, 5, 0, 60)
		settingsPanel.BackgroundColor3 = Color3.fromRGB(22, 22, 36)
		settingsPanel.BorderSizePixel = 0
		settingsPanel.Visible = false
		settingsPanel.ZIndex = 7
		settingsPanel.Parent = container

		Instance.new("UICorner", settingsPanel).CornerRadius = UDim.new(0, 8)
		local sp = Instance.new("UIStroke", settingsPanel)
		sp.Color = Color3.fromRGB(50, 50, 80)
		sp.Thickness = 1

		local settingsOpen = false
		settingsBtn.MouseButton1Click:Connect(function()
			settingsOpen = not settingsOpen
			settingsPanel.Visible = settingsOpen
			if settingsOpen then
				container.Size = UDim2.new(1, 0, 0, 150)
				settingsBtn.BackgroundColor3 = Color3.fromRGB(80, 60, 140)
			else
				container.Size = UDim2.new(1, 0, 0, 55)
				settingsBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
			end
		end)
	end

	return {
		container = container,
		btn = btn,
		icon = icon,
		label = label,
		status = status,
		btnStroke = btnStroke,
		settingsBtn = settingsBtn,
		settingsPanel = settingsPanel,
	}
end

local function createSlider(parent, text, min, max, default, callback)
	local sliderFrame = Instance.new("Frame")
	sliderFrame.Size = UDim2.new(1, -16, 0, 34)
	sliderFrame.Position = UDim2.new(0, 8, 0, 0)
	sliderFrame.BackgroundTransparency = 1
	sliderFrame.ZIndex = 8
	sliderFrame.Parent = parent

	local sLabel = Instance.new("TextLabel")
	sLabel.Size = UDim2.new(0.45, 0, 1, 0)
	sLabel.BackgroundTransparency = 1
	sLabel.Text = text
	sLabel.TextSize = 13
	sLabel.Font = Enum.Font.GothamBold
	sLabel.TextColor3 = Color3.fromRGB(170, 170, 200)
	sLabel.TextXAlignment = Enum.TextXAlignment.Left
	sLabel.ZIndex = 9
	sLabel.Parent = sliderFrame

	local valueLabel = Instance.new("TextLabel")
	valueLabel.Size = UDim2.new(0, 40, 0, 20)
	valueLabel.Position = UDim2.new(1, -40, 0.5, -10)
	valueLabel.BackgroundTransparency = 1
	valueLabel.Text = tostring(default)
	valueLabel.TextSize = 14
	valueLabel.Font = Enum.Font.GothamBold
	valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	valueLabel.ZIndex = 9
	valueLabel.Parent = sliderFrame

	local track = Instance.new("Frame")
	track.Size = UDim2.new(0.4, 0, 0, 6)
	track.Position = UDim2.new(0.45, 0, 0.5, -3)
	track.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
	track.BorderSizePixel = 0
	track.ZIndex = 9
	track.Parent = sliderFrame

	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(100, 80, 200)
	fill.BorderSizePixel = 0
	fill.ZIndex = 10
	fill.Parent = track

	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("TextButton")
	knob.Size = UDim2.new(0, 16, 0, 16)
	knob.Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8)
	knob.BackgroundColor3 = Color3.fromRGB(140, 120, 255)
	knob.Text = ""
	knob.AutoButtonColor = false
	knob.ZIndex = 11
	knob.Parent = track

	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local slideDragging = false

	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			slideDragging = true
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if slideDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local trackAbsPos = track.AbsolutePosition.X
			local trackAbsSize = track.AbsoluteSize.X
			local pct = math.clamp((input.Position.X - trackAbsPos) / trackAbsSize, 0, 1)
			local value = math.floor(min + (max - min) * pct)

			fill.Size = UDim2.new(pct, 0, 1, 0)
			knob.Position = UDim2.new(pct, -8, 0.5, -8)
			valueLabel.Text = tostring(value)
			callback(value)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			slideDragging = false
		end
	end)
end

